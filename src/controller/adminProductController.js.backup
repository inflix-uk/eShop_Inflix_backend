                if (Array.isArray(variant_Values)) {

                    // console.log(variant_Values );
                    // return;
                    variant_Values.forEach(item => {
                        VariantValueName = item.name;
                        const VariantValueCost = item.Cost;
                        const VariantValuePrice = item.Price;
                        const VariantSalePrice = item.salePrice;
                        const VariantValueQuantity = item.Quantity;
                        const VariantValueSKU = item.SKU;
                        const VariantValueEIN = item.EIN;
                        const VariantValueMPN = item.MPN;
                        const Seo_Meta_values = parseField(Seo_Meta);

                        // console.log(Seo_Meta_values );
                        // return;
                        if (productType_values.type === "single") {
                            const Seo_Meta_values = parseField(Seo_Meta);
                            variantValuesArray.push({
                                name: VariantValueName || "single",
                                Icon: null,
                                Cost: VariantValueCost || null,
                                Price: VariantValuePrice || null,
                                salePrice: VariantSalePrice || null,
                                Quantity: VariantValueQuantity || null,
                                SKU: VariantValueSKU || null,
                                EIN: VariantValueEIN || null,
                                MPN: VariantValueMPN || null,

                            });
                        }
                        // console.log("Seo_Meta_values",  Seo_Meta_values );
                        // return;
                        Seo_MetaObject = {
                            metaTitle: Seo_Meta_values.metaTitle || null,
                            metaDescription: Seo_Meta_values.metaDescription || null,
                            metaKeywords: Seo_Meta_values.metaKeywords || null,
                            metaSchemas: Seo_Meta_values.metaSchemas || null
                        };
                    });
                }
                // console.log(Seo_MetaObject);
                // return;

                if (req.body.meta_Image) {
                    meta_ImageObject = JSON.parse(req.body.meta_Image);
                }
                if (req.body.thumbnail_image) {

                    thumbnail_imageObject = JSON.parse(req.body.thumbnail_image);
                }
  
                if (req.body.Gallery_Images) {
                    let parsedGalleryImages = [];

                    if (typeof req.body.Gallery_Images === 'string') {
                        // Attempt to parse the string as a JSON object or array
                        try {
                            const galleryImages = JSON.parse(req.body.Gallery_Images);
                            if (Array.isArray(galleryImages)) {
                                parsedGalleryImages = galleryImages;
                            } else {
                                parsedGalleryImages = [galleryImages];
                            }
                        } catch (error) {
                            console.error('Error parsing Gallery_Images:', error);
                        }
                    } else if (Array.isArray(req.body.Gallery_Images)) {
                        // If it's already an array of strings, parse each one
                        parsedGalleryImages = req.body.Gallery_Images.map(imageStr => {
                            try {
                                return JSON.parse(imageStr);
                            } catch (error) {
                                console.error('Error parsing image string:', error);
                                return null;
                            }
                        }).filter(image => image !== null);
                    }

                    // Map to the desired structure
                    galleryImagesArray = parsedGalleryImages.map(image => ({
                        filename: image.filename,
                        path: image.path
                    }));
                }

                // ############ old code ##################
                // if (req.body.variantImages) {
                //     const variantImages = req.body.variantImages;
                //     const groupedImages = {};
                //     // console.log('variantImages',variantImages);
                //     // return;
                //     for (const key in variantImages) {
                //         const color = key.split('-')[1]; 
                //         if (!groupedImages[color]) {
                //             groupedImages[color] = [];
                //         }

                //         // Check if variantImages[key] is an array or a single string
                //         const imagesArray = Array.isArray(variantImages[key]) ? variantImages[key] : [variantImages[key]];

                //         imagesArray.forEach(imageStr => {
                //             try {
                //                 const image = JSON.parse(imageStr);
                //                 if (!groupedImages[color].some(img => img.path === image.path)) {
                //                     groupedImages[color].push(image);
                //                 }
                //             } catch (e) {
                //                 console.error(`Error parsing JSON for key ${key}:`, e);
                //             }
                //         });
                //     }

                //     // console.log('groupedImages',groupedImages);
                //     // return;
                //     varImgGroupArray = Object.keys(groupedImages).map(color => ({
                //         name: color,
                //         varImg: groupedImages[color]
                //     }));

                //     // Log the varImgGroupArray with complete data
                //     // console.log('varImgGroupArray', JSON.stringify(varImgGroupArray, null, 2));
                // }
                   // ############ end old code ##################

    
               
                
                   if (req.body.variantImages) {
                    const variantImages = req.body.variantImages;
                    console.log('variantImages: ', variantImages);
                    const groupedImages = {}; // To store grouped images by color
                
                    // List of compound color names
                    const compoundColors = [
                        "Phantom-Black", "Silver-Shadow", "Crafted-Black", "Phantom-Silver", "Phantom-Violet", "Pink-Gold",
                        "Sky-Blue", "Ice-Blue", "Cloud-Lavender", "Cloud-Navy", "Cloud-Mint", "Cloud-White", "Cloud-Red",
                        "Cloud-Orange", "Titanium-Black", "Titanium-Violet", "Titanium-Gray", "Titanium-Yellow", "Titanium-Blue",
                        "Titanium-Green", "Titanium-Orange", "Matte-Space-Gray", "Matte-Silver", "Matte-Gold", "Matte-Midnight-Green",
                        "Black-Titanium", "White-Titanium", "Blue-Titanium", "Natural-Titanium", "Rose-Gold", "Space-Gray",
                        "Deep-Purple", "Space-Black", "Light-Green", "Magical-Blue", "Brave-Black", "Prism-White", "Prism-Black",
                        "Prism-Green", "Prism-Blue", "Canary-Yellow", "Flamingo-Pink", "Cosmic-Grey", "Cloud-Blue", "Phantom-Brown",
                        "Cobalt-Violet", "Amber-Yellow", "Jade-Green", "Sandstone-Orange", "Sapphire-Blue", "Dark-Gray",
                        "Sierra-Blue", "Midnight-Black", "Lake-Blue", "Sunlight-Orange", "Poco-Yellow", "Cool-Blue", "Power-Black",
                        "Desert-Titanium", "Iron-Gray", "Electric-Violet", "Sunset-Dune", "Rose-Quartz", "Wintergreen", "Elegant-Black",
                        "Peacock-Blue", "Pearl-White"
                    ];
                
                    for (const variantKey in variantImages) {
                        let color;
                        let colorCode = null;
                
                        // Attempt to match a compound color
                        const compoundMatch = compoundColors.find((compoundColor) => variantKey.includes(compoundColor));
                        if (compoundMatch) {
                            color = compoundMatch; // Use matched compound color
                        } else {
                            // Fallback to extract color portion after the first `-`
                            const match = variantKey.match(/^[^-]+-(.+?)(?:\s|$)/);
                            color = match?.[1] || variantKey; // Use full key if no match
                        }
                
                        // Extract color code from the variantKey
                        const colorCodeMatch = variantKey.match(/\(#([a-fA-F0-9]{6})\)/);
                        if (colorCodeMatch) {
                            colorCode = `#${colorCodeMatch[1]}`;
                        }
                
                        // Initialize group for this color if it doesn't exist
                        if (!groupedImages[color]) {
                            groupedImages[color] = {
                                displayName: `${color} (${colorCode})`,
                                varImg: []
                            };
                        }
                
                        // Handle single or array images
                        const imageEntries = Array.isArray(variantImages[variantKey]) ? variantImages[variantKey] : [variantImages[variantKey]];
                
                        imageEntries.forEach((imageStr) => {
                            try {
                                const image = JSON.parse(imageStr); // Parse image JSON
                
                                if (!groupedImages[color].varImg.some((img) => img.path === image.path)) {
                                    groupedImages[color].varImg.push(image);
                                }
                            } catch (error) {
                                console.error(`Error parsing image JSON for key "${variantKey}":`, error);
                            }
                        });
                    }
                
                    // Transform groupedImages into the desired array format
                    varImgGroupArray = Object.keys(groupedImages).map((color) => ({
                        name: groupedImages[color].displayName,
                        varImg: groupedImages[color].varImg,
                    }));
                
                    // Log the final grouped structure
                    console.log('Grouped Images:', JSON.stringify(varImgGroupArray, null, 2));
                 
                }
                
                
                
                if (req.files) {
                    req.files.forEach(file => {
                        const fieldname = file.fieldname;
                        if (file.fieldname === 'meta_Image') {
                            meta_Image = file;
                        }

                        if (fieldname === 'thumbnail_image') {
                            thumbnail_image = file;

                        }
                        if (fieldname === 'Gallery_Images') {
                            Gallery_Images.push(file);

                            // galleryImages = Gallery_Images.map(image => ({
                            //     filename: image.filename,
                            //     path: image.path
                            // }));
                            galleryImagesArray.push({
                                filename: file.filename,
                                path: file.path
                            });

                        }
                    });
                }

                // console.log('galleryImagesArray', galleryImagesArray)
                // return;
                let parsedVariants = {}; // Initialize parsedVariants as an object
                // console.log( 'productType',  productType_values.type);
                // return;

                // console.log(req.files);
                if (productType_values.type === 'variant') {
                    const { variantValues, variantImages, variantMetaImage } = req.body;

                    // Initialize parsed_Variant_Images as an object
                    let parsed_Variant_Images = {};
                    let parsed_Variant_Meta_Images = {};
                    const varImgGroup = {};

                    if (req.files) {
                        // Iterate over each file in req.files
                        req.files.forEach(file => {
                            const field = file.fieldname;

                            if (field.startsWith('variantMetaImage[') && field.endsWith(']')) {
                                const startIdx = field.indexOf('[') + 1;
                                const endIdx = field.indexOf(']');
                                const variantKey = field.slice(startIdx, endIdx);
                                if (!parsed_Variant_Meta_Images[variantKey]) {
                                    parsed_Variant_Meta_Images[variantKey] = [];
                                }
                                parsed_Variant_Meta_Images[variantKey].push({
                                    filename: file.filename,
                                    path: file.path,
                                });
                            }


                            // Check if the fieldname corresponds to variantImages
                            if (field.startsWith('variantImages[') && field.endsWith(']')) {
                                const startIdx = field.indexOf('[') + 1;
                                const endIdx = field.indexOf(']');
                                const variantKey = field.slice(startIdx, endIdx);

                                // Initialize array for the variant key if it doesn't exist
                                if (!parsed_Variant_Images[variantKey]) {
                                    parsed_Variant_Images[variantKey] = [];
                                }

                                // Push file details to the variant key array
                                parsed_Variant_Images[variantKey].push({
                                    filename: file.filename,
                                    path: file.path,
                                });
                            }

                            else if (field.startsWith('varImg[') && field.endsWith(']')) {
                                const startIdx = field.indexOf('[') + 1;
                                const endIdx = field.indexOf(']');
                                const variantKey = field.slice(startIdx, endIdx);

                                if (!varImgGroup[variantKey]) {
                                    varImgGroup[variantKey] = [];
                                }

                                // Add the new uploaded image
                                varImgGroup[variantKey].push({
                                    filename: file.filename,
                                    path: file.path,
                                });
                            }

                            // After processing all files, merge with the existing images from req.body.variantImages
                            if (req.body.variantImages) {
                                const variantImages = req.body.variantImages;
                                for (const key in variantImages) {
                                    const color = key.split('-')[1]; // Extract color from key
                                    if (!varImgGroup[color]) {
                                        varImgGroup[color] = [];
                                    }

                                    // Check if variantImages[key] is an array or a single string
                                    const imagesArray = Array.isArray(variantImages[key]) ? variantImages[key] : [variantImages[key]];

                                    imagesArray.forEach(imageStr => {
                                        try {
                                            const image = JSON.parse(imageStr);
                                            if (!varImgGroup[color].some(img => img.path === image.path)) {
                                                varImgGroup[color].push(image);
                                            }
                                        } catch (e) {
                                            console.error(`Error parsing JSON for key ${key}:`, e);
                                        }
                                    });
                                }
                            }

                            varImgGroupArray = Object.keys(varImgGroup).map(variantKey => ({
                                name: variantKey,
                                varImg: varImgGroup[variantKey]
                            }));

                            // console.log("varImgGroupArray", varImgGroupArray);


                            // Convert varImgGroup object into an array of documents


                        });
                    }
                    console.log("varImgGroupArray:", JSON.stringify(varImgGroupArray, null, 2));

                  
                    


                    parsedMetaImages = parsed_Variant_Meta_Images;

                    parsedVariants = parsed_Variant_Images;


                    const parsedVariantValues = typeof variantValues === 'string' ? JSON.parse(variantValues) : variantValues;
                    const parsedVariantImages = typeof variantImages === 'string' ? JSON.parse(variantImages) : variantImages;
                    const parsedvariantMetaImage = typeof variantMetaImage === 'string' ? JSON.parse(variantMetaImage) : variantMetaImage;
                    // console.log("parsedVariantValues", parsedVariantValues);
                    // return;
                    for (const key in parsedVariantValues) {
                        if (Object.hasOwnProperty.call(parsedVariantValues, key)) {
                            const variantValue = parsedVariantValues[key];
                            const parsedVariant = parsedVariants[key] || [];
                            const variantmetaImage = parsedMetaImages[key] || [];

                            let images = parsedVariant;
                            if (parsedVariantImages && parsedVariantImages[key]) {
                                // Check if parsedVariantImages[key] is an array or a single string
                                const existingImages = Array.isArray(parsedVariantImages[key])
                                    ? parsedVariantImages[key].map(imageStr => {
                                        try {
                                            return JSON.parse(imageStr);
                                        } catch (e) {
                                            console.error('Invalid JSON in variantImages:', e);
                                            return null;
                                        }
                                    }).filter(image => image !== null)
                                    : (() => {
                                        try {
                                            return [JSON.parse(parsedVariantImages[key])];
                                        } catch (e) {
                                            console.error('Invalid JSON in variantImages:', e);
                                            return [];
                                        }
                                    })();

                                images = images.concat(existingImages);
                            }


                            // Further processing of images if needed
                            // console.log('Images:', images);

                            // return;

                            let variantMetaImageObject = null;
                            if (parsedvariantMetaImage && parsedvariantMetaImage[key]) {
                                try {
                                    const variantMetaImage = JSON.parse(parsedvariantMetaImage[key]);
                                    if (Array.isArray(variantMetaImage)) {
                                        variantMetaImageObject = {
                                            filename: variantMetaImage[0].filename,
                                            path: variantMetaImage[0].path
                                        };
                                    } else if (typeof variantMetaImage === 'object') {
                                        variantMetaImageObject = {
                                            filename: variantMetaImage.filename,
                                            path: variantMetaImage.path
                                        };
                                    }
                                } catch (e) {
                                    console.error('Invalid JSON in parsedvariantMetaImage:', e);
                                }
                            }
                            // console.log('Variant:', key.trim(), 'variantMetaImageObject:', variantMetaImageObject);
                            variantValuesArray.push({
                                name: key.trim(),
                                variantImages: images || parsedVariant,
                                Cost: variantValue.Cost || null,
                                Price: variantValue.Price || null,
                                Quantity: variantValue.Quantity || null,
                                SKU: variantValue.SKU || null,
                                EIN: variantValue.EIN || null,
                                salePrice: variantValue.salePrice || null,
                                metaTitle: variantValue.metaTitle || null,
                                metaDescription: variantValue.metaDescription || null,
                                metaKeywords: variantValue.metaKeywords || null,
                                metaSchemas: variantValue.metaSchemas || null,
                                // metaImage: variantmetaImage.length > 0 ? variantmetaImage[0] : null
                                metaImage: variantmetaImage.length > 0 ? variantmetaImage[0] : variantMetaImageObject,
                                MPN:  variantValue.MPN || null,
                            });
                        }
                    }

                    const variantNamesData = JSON.parse(req.body.variantNames);
                    variantNamesData.forEach(variantName => {
                        const { name, options } = variantName;
                        variantNamesArray.push({
                            name,
                            options
                        });
                    });
                }
                // console.log(seeAccessoriesWeDontNeed);
                // return;


                product.name = name;
                product.producturl = producturl;
                product.category = category;
                product.tags = tags;
                product.subCategory = subcategory;
                product.brand = brand;
                product.battery = battery || null;

                product.condition = condition;
                product.is_featured = is_featured;
                product.seeAccessoriesWeDontNeed = seeAccessoriesWeDontNeed === 'true' ? true : seeAccessoriesWeDontNeed === 'false' ? false : null;
                product.is_refundable = {
                    status: is_refundable_Values.status,
                    refund_duration: is_refundable_Values.refund_duration,
                    refund_type: is_refundable_Values.refund_type

                },
                    product.is_authenticated = is_authenticated;
                // product.low_stock_quantity_alert = low_stock_quantity_alert || null;
                product.low_stock_quantity_alert = low_stock_quantity_alert !== null && low_stock_quantity_alert !== undefined && !isNaN(Number(low_stock_quantity_alert))
                    ? Number(low_stock_quantity_alert)
                    : null;

                // product.Shipping_Information = {
                //     Weight: Shipping_InformationValues.Weight,
                //     Height: Shipping_InformationValues.Height,
                //     Width: Shipping_InformationValues.Width,
                //     Length: Shipping_InformationValues.Length
                // };
                product.thumbnail_image = {
                    filename: thumbnail_image.filename || thumbnail_imageObject.filename,
                    path: thumbnail_image.path || thumbnail_imageObject.path
                };

                product.Gallery_Images = galleryImagesArray.length > 0 ? galleryImagesArray : galleryImages;
                product.has_warranty = {
                    status: has_warrantyvalues.status,
                    has_replacement_warranty: has_warrantyvalues.has_replacement_warranty,
                    Warranty_duration: has_warrantyvalues.Warranty_duration,
                    Warranty_type: has_warrantyvalues.Warranty_type

                },
                    product.productType = {
                        type: productType_values.type
                    };

                product.variantNames = variantNamesArray;
                product.variantValues = variantValuesArray;
                product.variantDescription = variantDesc_values || null;

                product.varImgGroup = varImgGroupArray || null,


                    product.sim_options = sim_options || null,
                    product.product_Specifications = specifications_values,

                    product.comes_With = {
                        powerAdapter: comes_with_values.powerAdapter,
                        powerCable: comes_with_values.powerCable,
                        protectionBundle: comes_with_values.protectionBundle,
                        treePlanted: comes_with_values.treePlanted,
                        hdmi: comes_with_values.hdmi,
                        powerCableNewIncluded: comes_with_values.powerCableNewIncluded,
                        onexcontroller: comes_with_values.onexcontroller,
                        twoxcontroller: comes_with_values.twoxcontroller,
                        freeSim: comes_with_values.freeSim,
                        onexBackCover:comes_with_values.onexBackCover,
                        onexScreenProtector:comes_with_values.onexScreenProtector,

                    };

                // product.discount = {
                //     discount_value: discount_values.discount_value,
                //     discount_type: discount_values.discount_type
                // };

                // product.Purchase_Quantity = {
                //     min_quantity: Purchase_Quantity_values.min_quantity,
                //     max_quantity: Purchase_Quantity_values.max_quantity
                // };
                product.Product_summary = Product_summary;
                product.Product_description = Product_description;
                product.Seo_Meta = Seo_MetaObject || null;
                product.status = status;
                product.meta_Image = {
                    filename: meta_ImageObject.filename || meta_Image.fieldname,
                    path: meta_ImageObject.path || meta_Image.path
                };
                const updatedProduct = product.updatedAt = Date.now();
                console.log('updatedProduct', updatedProduct);
                

                const savedProduct = await product.save().catch(error => {
                    console.error('Error saving product:', error);
                    throw error;
                });

                return res.json({ message: 'Product updated successfully', product: savedProduct, status: 201 });
            });

        } catch (error) {
            console.error('Error updating product:', error);
            return res.json({ message: 'Failed to update product', status: 500 });
        }
    },

    deleteProduct: async (req, res) => {
        try {
            const { id } = req.params;
            console.log(req.params);
            console.log(id);

           
            const deletedProduct = await Product.findByIdAndUpdate(id, { isdeleted: true },{ status: false }, { new: true });
            if (!deletedProduct) {
                return res.json({ message: 'Product not found', status: 404 });
            }
            return res.json({ message: 'Product deleted successfully', deletedProduct, status: 201 });
        } catch (error) {
            console.error('Error deleting product:', error);
            return res.json({ message: 'Failed to delete product', status: 500 });
        }
    },

