                        hdmi: comes_with_values.hdmi,
                        powerCableNewIncluded: comes_with_values.powerCableNewIncluded,
                        onexcontroller: comes_with_values.onexcontroller,
                        twoxcontroller: comes_with_values.twoxcontroller,
                        freeSim: comes_with_values.freeSim,
                        onexBackCover:comes_with_values.onexBackCover,
                        onexScreenProtector:comes_with_values.onexScreenProtector,

                    },
                    // Shipping_Information: {
                    //     Weight: Shipping_InformationValues.weight,
                    //     Height: Shipping_InformationValues.height,
                    //     Width: Shipping_InformationValues.width,
                    //     Length: Shipping_InformationValues.length
                    // },
                    thumbnail_image: {
                        filename: thumbnailImage ? thumbnailImage.filename : null,
                        path: thumbnailImage ? thumbnailImage.path : null
                    },
                    Gallery_Images: galleryImages,
                    has_warranty: {
                        status: has_warrantyvalues.has_warranty,
                        has_replacement_warranty: has_warrantyvalues.has_replacement_warranty,
                        Warranty_duration: has_warrantyvalues.warranty_duration,
                        Warranty_type: has_warrantyvalues.warranty_type

                    },
                    productType: {
                        type: productType_values.type
                    },
                    // Add variantValuesArray to the newProduct object
                    variantValues: variantValuesArray || null,
                    variantNames: variantNamesArray || null,
                    varImgGroup: varImgGroupArray || null,
                    // discount: {
                    //     discount_value: discount_values.discount, 
                    //     discount_type: discount_values.discountType
                    // },
                    // Purchase_Quantity: {
                    //     min_quantity: Purchase_Quantity_values.min,
                    //     max_quantity: Purchase_Quantity_values.max
