                    },

                    status: status,
                    publishAt: Date.now(),
                    createdAt: Date.now(),
                    updatedAt: Date.now()
                });

                // Save the product to the database
                // console.log('New Product:', newProduct); // Debug statement

                const savedProduct = await newProduct.save().catch(error => {
                    console.error('Error saving product:', error);
